APP_NAME="Factory Management System"
APP_ENV=local
APP_KEY=base64:$(openssl rand -base64 32)
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=factory_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_LIFETIME=40
SESSION_ABSOLUTE_TIMEOUT=480

BACKUP_PASSWORD=secret_encryption_key
